<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             xmlns:vm="clr-namespace:Messenger.Desktop.ViewModels"
             x:DataType="vm:LoginViewModel"
             x:Class="Messenger.Desktop.Views.LoginView">
    <Design.DataContext>
        <vm:LoginViewModel></vm:LoginViewModel>
    </Design.DataContext>
    
    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
        <Border Padding="12">
            <StackPanel MinWidth="210">
                <TextBlock Text="Alice:"></TextBlock>
                <TextBox Text="{Binding Alice}" Watermark="Input your alice..."></TextBox>
                <Button Command="{Binding LoginCommand}"
                        Content="Login"></Button>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
